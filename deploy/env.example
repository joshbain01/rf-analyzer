# rf-monitor environment overrides for systemd
# Install: sudo cp deploy/env.example /etc/rf-monitor/env
# Edit values as needed for your deployment.
#
# These are read by the systemd EnvironmentFile= directive and act as
# the environment variable override tier in rf-monitor's config hierarchy.

# Frequency range (narrow range = faster scans = less Pi heat)
RF_MONITOR_FREQ_START=100M
RF_MONITOR_FREQ_END=500M

# Scan resolution and timing
RF_MONITOR_BIN_SIZE=50k
RF_MONITOR_INTEGRATION_TIME=0.4s
RF_MONITOR_INTERVAL=60

# Gain (0 = auto, 40-50 for weak signals)
RF_MONITOR_GAIN=40

# Alert threshold in dBm
RF_MONITOR_ALERT_THRESHOLD=-50

# Output
RF_MONITOR_OUTPUT_DIR=/var/log/rf-monitor/scans

# Log retention (days)
RF_MONITOR_MAX_LOG_AGE=7

# udev rules for RTL-SDR USB devices
# Install: sudo cp deploy/99-rtlsdr.rules /etc/udev/rules.d/
# Reload: sudo udevadm control --reload-rules && sudo udevadm trigger
#
# Grants access to the 'plugdev' group, which the rf-monitor service user
# must be a member of. This avoids running the service as root.

# RTL2832U (most common RTL-SDR chipset)
SUBSYSTEM=="usb", ATTRS{idVendor}=="0bda", ATTRS{idProduct}=="2832", GROUP="plugdev", MODE="0660", SYMLINK+="rtlsdr"
SUBSYSTEM=="usb", ATTRS{idVendor}=="0bda", ATTRS{idProduct}=="2838", GROUP="plugdev", MODE="0660", SYMLINK+="rtlsdr"

# RTL-SDR Blog V4 (with different PID)
SUBSYSTEM=="usb", ATTRS{idVendor}=="0bda", ATTRS{idProduct}=="2833", GROUP="plugdev", MODE="0660", SYMLINK+="rtlsdr"

# NooElec variants
SUBSYSTEM=="usb", ATTRS{idVendor}=="0bda", ATTRS{idProduct}=="2834", GROUP="plugdev", MODE="0660", SYMLINK+="rtlsdr"
SUBSYSTEM=="usb", ATTRS{idVendor}=="0bda", ATTRS{idProduct}=="2837", GROUP="plugdev", MODE="0660", SYMLINK+="rtlsdr"
SUBSYSTEM=="usb", ATTRS{idVendor}=="0bda", ATTRS{idProduct}=="2839", GROUP="plugdev", MODE="0660", SYMLINK+="rtlsdr"

# Wideband profile: broader coverage with lower time resolution
RF_MONITOR_FREQ_START=100M
RF_MONITOR_FREQ_END=900M
RF_MONITOR_BIN_SIZE=100k
RF_MONITOR_INTEGRATION_TIME=0.4s
RF_MONITOR_INTERVAL=120
RF_MONITOR_GAIN=35
RF_MONITOR_ALERT_THRESHOLD=-50
RF_MONITOR_OUTPUT_DIR=/var/log/rf-monitor/scans
RF_MONITOR_MAX_LOG_AGE=7

# High-sensitivity profile: narrower range and longer dwell for weak-signal detection
RF_MONITOR_FREQ_START=200M
RF_MONITOR_FREQ_END=450M
RF_MONITOR_BIN_SIZE=25k
RF_MONITOR_INTEGRATION_TIME=1s
RF_MONITOR_INTERVAL=90
RF_MONITOR_GAIN=50
RF_MONITOR_ALERT_THRESHOLD=-60
RF_MONITOR_OUTPUT_DIR=/var/log/rf-monitor/scans
RF_MONITOR_MAX_LOG_AGE=14
